# ── __PROJECT__ (n8n) ────────────────────────────────
# __ROOT:KEY__ = create-project.sh เติมค่าจาก .env กลางให้อัตโนมัติ
APP_DOMAIN=__PROJECT__.__ROOT:BASE_DOMAIN__
TZ=__ROOT:TZ__

# openssl rand -hex 24  — ⚠️ ต้องตั้งเอง + ห้ามเปลี่ยนหลังใช้งาน (credentials จะถอดรหัสไม่ได้)
N8N_ENCRYPTION_KEY=

DB_DATABASE=__PROJECT___db
