# ── __PROJECT__ (Laravel) ────────────────────────────
APP_IMAGE=ghcr.io/korwlik23/__PROJECT__:latest
APP_DOMAIN=__PROJECT__.example.com

APP_NAME=__PROJECT__
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://__PROJECT__.example.com

# Database — ผ่าน network `backend` (สร้าง db ก่อน: CREATE DATABASE __PROJECT___db)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=__PROJECT___db
DB_USERNAME=infra
DB_PASSWORD=CHANGE_ME

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Cloudflare R2 (S3-compatible)
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_DEFAULT_REGION=auto
AWS_BUCKET=__PROJECT__
AWS_ENDPOINT=https://CHANGE_ME.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true
