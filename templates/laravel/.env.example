# ── __PROJECT__ (Laravel) ────────────────────────────
# __ROOT:KEY__ = create-project.sh เติมค่าจาก .env กลางให้อัตโนมัติ
APP_IMAGE=ghcr.io/korwlik23/__PROJECT__:latest
APP_DOMAIN=__PROJECT__.__ROOT:BASE_DOMAIN__

# Zero-downtime rolling deploy (docs/25-zero-downtime.md)
ROLLOUT_SERVICE=__PROJECT__-app
HEALTHCHECK_PATH=/up
# รัน migration อัตโนมัติก่อนสลับ traffic ทุก deploy (Laravel = ควรเปิด)
# migration ต้องเป็น expand/contract เสมอ — ดู docs/25
DEPLOY_MIGRATE=1

APP_NAME=__PROJECT__
APP_ENV=production
APP_KEY=                              # ⚠️ ต้องตั้งเอง: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://__PROJECT__.__ROOT:BASE_DOMAIN__

# Database — ผ่าน network `backend` (สร้าง db ก่อน: CREATE DATABASE __PROJECT___db)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=__PROJECT___db
DB_USERNAME=__ROOT:POSTGRES_USER__
DB_PASSWORD=__ROOT:POSTGRES_PASSWORD__

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=__ROOT:REDIS_PASSWORD__
REDIS_PORT=6379
REDIS_CLIENT=predis                   # ใช้ predis ถ้า image ไม่มี phpredis extension
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Cloudflare R2 (S3-compatible) — ดึงจาก .env กลาง (ถ้าตั้งค่า R2 แล้ว)
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=__ROOT:R2_ACCESS_KEY_ID__
AWS_SECRET_ACCESS_KEY=__ROOT:R2_SECRET_ACCESS_KEY__
AWS_DEFAULT_REGION=auto
AWS_BUCKET=__PROJECT__
AWS_ENDPOINT=https://__ROOT:R2_ACCOUNT_ID__.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true
