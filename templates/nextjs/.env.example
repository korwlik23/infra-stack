# ── __PROJECT__ (Next.js) ────────────────────────────
# __ROOT:KEY__ = create-project.sh เติมค่าจาก .env กลางให้อัตโนมัติ
APP_IMAGE=ghcr.io/korwlik23/__PROJECT__:latest
APP_DOMAIN=__PROJECT__.__ROOT:BASE_DOMAIN__

# Zero-downtime rolling deploy (docs/25-zero-downtime.md)
ROLLOUT_SERVICE=__PROJECT__
# แนะนำสร้าง /api/health ที่ตอบเร็ว แล้วเปลี่ยนค่านี้ (default: หน้าแรก)
HEALTHCHECK_PATH=/

NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://__PROJECT__.__ROOT:BASE_DOMAIN__

# ถ้าใช้ database ตรง (เช่น Prisma) — ผ่าน network `backend`
DATABASE_URL=postgresql://__ROOT:POSTGRES_USER__:__ROOT:POSTGRES_PASSWORD__@postgres:5432/__PROJECT___db

# Redis (cache / rate limit)
REDIS_URL=redis://:__ROOT:REDIS_PASSWORD__@redis:6379
