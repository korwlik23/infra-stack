# ── __PROJECT__ (AI Worker) ──────────────────────────
APP_IMAGE=ghcr.io/korwlik23/__PROJECT__:latest
WORKER_COMMAND=python worker.py

# Resource limits — worker AI (FFmpeg/gen image) กันลากทั้งเครื่อง
WORKER_MEM_LIMIT=2g
WORKER_CPUS=2

# Queue — เลือกอย่างใดอย่างหนึ่ง
REDIS_URL=redis://:CHANGE_ME@redis:6379
RABBITMQ_URL=amqp://infra:CHANGE_ME@rabbitmq:5672

# AI APIs
OPENAI_API_KEY=CHANGE_ME

# Output → R2
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_ENDPOINT=https://CHANGE_ME.r2.cloudflarestorage.com
R2_BUCKET=images
