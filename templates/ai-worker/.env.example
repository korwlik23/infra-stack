# ── __PROJECT__ (AI Worker) ──────────────────────────
# __ROOT:KEY__ = create-project.sh เติมค่าจาก .env กลางให้อัตโนมัติ
APP_IMAGE=ghcr.io/korwlik23/__PROJECT__:latest
WORKER_COMMAND=python worker.py

# Resource limits — worker AI (FFmpeg/gen image) กันลากทั้งเครื่อง
WORKER_MEM_LIMIT=2g
WORKER_CPUS=2

# Queue — เลือกอย่างใดอย่างหนึ่ง
REDIS_URL=redis://:__ROOT:REDIS_PASSWORD__@redis:6379
RABBITMQ_URL=amqp://__ROOT:RABBITMQ_USER__:__ROOT:RABBITMQ_PASSWORD__@rabbitmq:5672

# AI APIs — ⚠️ ต้องตั้งเอง
OPENAI_API_KEY=

# Output → R2 (ดึงจาก .env กลาง ถ้าตั้งค่าแล้ว)
R2_ACCESS_KEY_ID=__ROOT:R2_ACCESS_KEY_ID__
R2_SECRET_ACCESS_KEY=__ROOT:R2_SECRET_ACCESS_KEY__
R2_ENDPOINT=https://__ROOT:R2_ACCOUNT_ID__.r2.cloudflarestorage.com
R2_BUCKET=images
