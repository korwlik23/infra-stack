# ── InfraStack global configuration ─────────────────
# Copy to .env and edit. NEVER commit the real .env.

# Base domain — every service gets a subdomain of this
BASE_DOMAIN=example.com

# Email used for Let's Encrypt certificate registration
ACME_EMAIL=admin@example.com

# Server timezone
TZ=Asia/Bangkok

# ── PostgreSQL ───────────────────────────────────────
POSTGRES_USER=infra
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=infra

# ── Redis ────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME

# ── Grafana ──────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── Cloudflare R2 (object storage / backup target) ──
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_BACKUP=backup
